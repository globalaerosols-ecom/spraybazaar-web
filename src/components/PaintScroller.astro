---
const paintProducts = [
    { id: 1, name: "Aura Matte Cyan", brand: "Aura", price: "24.00", img: "/images/paints/paint-product.png", type: "Matte", desc: "Deep matte finish with zero glare." },
    { id: 2, name: "Zenith Metallic Gold", brand: "Zenith", price: "32.00", img: "/images/paints/paint-product.png", type: "Metallic", desc: "Reflective gold for premium projects." },
    { id: 3, name: "Onyx Carbon Slate", brand: "Onyx", price: "28.00", img: "/images/paints/paint-product.png", type: "Industrial", desc: "Weather-resistant carbon coating." },
    { id: 4, name: "Vibe Neon Pink", brand: "Vibe", price: "20.00", img: "/images/paints/paint-product.png", type: "Fluorescent", desc: "Ultra-bright neon for high visibility." },
    { id: 5, name: "Aura Gloss White", brand: "Aura", price: "22.00", img: "/images/paints/paint-product.png", type: "Gloss", desc: "High-shine protective finish." },
    { id: 6, name: "Silk Satin Teal", brand: "Silk", price: "26.00", img: "/images/paints/paint-product.png", type: "Satin", desc: "Subtle sheen for interior decor." }
];
---
<section class="paint-scroller-section w-full py-32 bg-white overflow-hidden">
    <div class="px-6 lg:px-24 mb-16 flex justify-between items-end">
        <div>
            <span class="text-[#2b65ff] text-[10px] font-black uppercase tracking-[0.4em] mb-4 block animate-fade">Trending Series</span>
            <h2 class="text-5xl md:text-7xl font-black tracking-tighter leading-none">THE <span class="text-zinc-200">COLOR</span> STACK</h2>
        </div>
        <div class="hidden md:flex gap-4">
            <button class="scroll-prev w-12 h-12 rounded-full border border-zinc-200 flex items-center justify-center hover:bg-[#2b65ff] hover:text-white transition-colors">←</button>
            <button class="scroll-next w-12 h-12 rounded-full border border-zinc-200 flex items-center justify-center hover:bg-[#2b65ff] hover:text-white transition-colors">→</button>
        </div>
    </div>

    <!-- Horizontal Scroll Container -->
    <div class="scroller-container flex gap-8 overflow-x-hidden px-6 lg:px-24 cursor-grab select-none no-scrollbar">
        {paintProducts.map((product) => (
            <div class="scroller-item min-w-[300px] md:min-w-[400px] group">
                <div class="aspect-[4/5] w-full bg-[#fbfbfb] rounded-3xl overflow-hidden mb-8 shadow-sm transition-shadow group-hover:shadow-xl group-hover:shadow-[#2b65ff]/5">
                    <img src={product.img} alt={product.name} class="w-full h-full object-contain p-12 transition-transform duration-700 group-hover:scale-110" loading="lazy" />
                </div>
                <div class="px-4">
                    <p class="text-[9px] font-black tracking-[0.3em] text-[#2b65ff] uppercase mb-2">{product.brand}</p>
                    <h4 class="text-2xl font-bold tracking-tighter mb-4">{product.name}</h4>
                    <div class="flex items-center justify-between">
                        <span class="text-xl font-black">${product.price}</span>
                        <button class="bg-black text-white text-[10px] font-bold uppercase tracking-widest px-6 py-3 rounded-full hover:bg-[#2b65ff] transition-colors">Buy Now</button>
                    </div>
                </div>
            </div>
        ))}
    </div>
</section>

<script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
        if (typeof gsap === 'undefined') return;

        const container = document.querySelector('.scroller-container');
        const next = document.querySelector('.scroll-next');
        const prev = document.querySelector('.scroll-prev');

        const scrollAmount = 450;

        next.addEventListener('click', () => {
            container.scrollBy({ left: scrollAmount, behavior: 'smooth' });
        });

        prev.addEventListener('click', () => {
            container.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
        });
    });
</script>

<style>
    .no-scrollbar::-webkit-scrollbar {
        display: none;
    }
    .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>
