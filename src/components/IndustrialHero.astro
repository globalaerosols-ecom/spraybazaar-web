---
---
<section class="industrial-hero relative w-full h-screen overflow-hidden bg-[#0a0a0c] flex flex-col md:flex-row">
    <!-- Left Side: Maintenance / Lubrication -->
    <div class="relative w-full md:w-1/2 h-1/2 md:h-full overflow-hidden group border-r border-white/5">
        <div class="hero-split-img absolute inset-0 transition-transform duration-[3s] ease-out group-hover:scale-110">
            <img src="/images/industrial/hero_maintenance.png" class="w-full h-full object-cover grayscale opacity-60 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-1000" alt="Mechanical Maintenance">
        </div>
        <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent z-10"></div>
        
        <div class="absolute bottom-0 left-0 w-full p-12 z-20 split-content-left opacity-0 transform translate-y-8">
            <span class="text-[#2b65ff] text-[10px] font-black uppercase tracking-[0.4em] mb-4 block">Series M • Maintenance</span>
            <h2 class="text-4xl md:text-6xl font-black tracking-tighter leading-tight mb-6 text-white">
                PRECISION <br/> AEROSOLS.
            </h2>
            <p class="text-zinc-400 text-sm max-w-xs font-medium leading-relaxed mb-8">
                Ultra-penetrating aerosol formulas designed for high-cycle industrial machinery.
            </p>
            <button class="px-8 py-3 rounded-full border border-white/10 text-[10px] font-black uppercase tracking-widest text-white hover:bg-white hover:text-black transition-all">
                View Lubricants →
            </button>
        </div>
    </div>

    <!-- Right Side: Protection / Zinc -->
    <div class="relative w-full md:w-1/2 h-1/2 md:h-full overflow-hidden group">
        <div class="hero-split-img absolute inset-0 transition-transform duration-[3s] ease-out group-hover:scale-110">
            <img src="/images/industrial/hero_protection.png" class="w-full h-full object-cover grayscale opacity-60 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-1000" alt="Industrial Protection">
        </div>
        <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent z-10"></div>
        
        <div class="absolute bottom-0 left-0 w-full p-12 z-20 split-content-right opacity-0 transform translate-y-8">
            <span class="text-[#2b65ff] text-[10px] font-black uppercase tracking-[0.4em] mb-4 block">Series Z • Protection</span>
            <h2 class="text-4xl md:text-6xl font-black tracking-tighter leading-tight mb-6 text-white">
                HEAVY DUTY <br/> GALVANIZING.
            </h2>
            <p class="text-zinc-400 text-sm max-w-xs font-medium leading-relaxed mb-8">
                99.9% pure zinc spray for extreme corrosion resistance in harsh environments.
            </p>
            <button class="px-8 py-3 rounded-full border border-white/10 text-[10px] font-black uppercase tracking-widest text-white hover:bg-white hover:text-black transition-all">
                Explore Coatings →
            </button>
        </div>
    </div>

    <!-- Top Centered Title -->
    <div class="absolute top-28 md:top-36 left-1/2 -translate-x-1/2 z-40 w-full text-center px-6 industrial-main-title opacity-0 transform -translate-y-4">
        <h1 class="text-3xl md:text-8xl font-black tracking-tighter drop-shadow-2xl" style="font-family: 'Plus Jakarta Sans', sans-serif;">
            <span class="text-white mix-blend-difference">Industrial</span> <span class="text-[#2b65ff]">Aerosols</span>
        </h1>
    </div>
</section>

<script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
        if (typeof gsap === 'undefined') return;

        const tl = gsap.timeline();

        tl.to(".industrial-main-title", {
            opacity: 1,
            y: 0,
            duration: 1.5,
            ease: "power4.out"
        })
        .to(".split-content-left", {
            opacity: 1,
            y: 0,
            duration: 1.2,
            ease: "power4.out"
        }, "-=1.2")
        .to(".split-content-right", {
            opacity: 1,
            y: 0,
            duration: 1.2,
            ease: "power4.out"
        }, "-=1");

        // Move backwards and settle animation
        gsap.set(".hero-split-img", { scale: 1.1 });
        gsap.from(".hero-split-img", {
            scale: 1.6,
            duration: 2.5,
            ease: "power4.out",
            stagger: 0.1,
            force3D: true
        });

        // Subtle side-to-side drift for images
        gsap.to(".hero-split-img", {
            x: -20,
            duration: 20,
            repeat: -1,
            yoyo: true,
            ease: "sine.inOut"
        });
    });
</script>

<style>
    .industrial-hero {
        background-color: #000;
    }
</style>
