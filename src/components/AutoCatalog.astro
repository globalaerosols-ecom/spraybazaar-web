---
const autoListProducts = [
    { id: 41, name: "High Temp Brake Paint", brand: "AutoElite", price: "24.00", img: "https://images.unsplash.com/photo-1607860108855-64acf2078ed9?fm=webp&w=800&q=70&fit=crop", type: "Custom" },
    { id: 42, name: "Underbody Guard", brand: "AutoElite", price: "32.00", img: "https://images.unsplash.com/photo-1486006920555-c77dcf18193c?fm=webp&w=800&q=70&fit=crop", type: "Protection" },
    { id: 43, name: "Chrome Trim Polish", brand: "AutoElite", price: "18.00", img: "https://images.unsplash.com/photo-1489824904134-891ab64532f1?fm=webp&w=800&q=70&fit=crop", type: "Care" },
    { id: 44, name: "Vinyl Interior Dye", brand: "AutoElite", price: "26.00", img: "https://images.unsplash.com/photo-1549399542-7e3f8b79c34b?fm=webp&w=800&q=70&fit=crop", type: "Renewal" },
    { id: 45, name: "Bumper Renew Spray", brand: "AutoElite", price: "20.00", img: "https://images.unsplash.com/photo-1511919884226-fd3cad34687c?fm=webp&w=800&q=70&fit=crop", type: "Restoration" },
    { id: 46, name: "Engine Bay Degreaser", brand: "AutoElite", price: "16.50", img: "https://images.unsplash.com/photo-1503376780353-7e6692767b70?fm=webp&w=800&q=70&fit=crop", type: "Technical" }
];
---
<section id="auto-catalog" class="w-full py-32 bg-white relative overflow-hidden min-h-[600px]">
    <div class="px-6 lg:px-24 mb-20 flex flex-col md:flex-row justify-between items-end gap-8">
        <div>
            <span class="catalog-label-auto text-[#e11d48] text-[10px] font-black uppercase tracking-[0.4em] mb-4 block">Automotive Catalog</span>
            <h2 class="catalog-title-auto text-5xl md:text-7xl font-black tracking-tighter leading-none text-zinc-900">PEAK <span class="text-[#e11d48]">PERFORMANCE.</span></h2>
        </div>
        <div class="hidden md:block">
            <p class="catalog-desc-auto text-zinc-400 text-sm max-w-[250px] font-medium leading-relaxed">
                Professional vehicle care and mechanical aerosols engineered for ultimate results.
            </p>
        </div>
    </div>

    <div class="max-w-[1400px] mx-auto px-6 lg:px-24">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-2">
            {autoListProducts.map((product) => (
                <div class="catalog-item-auto flex items-center gap-8 py-8 border-b border-zinc-100 hover:bg-[#fbfbfb] px-6 transition-all duration-500 group cursor-pointer rounded-xl hover:translate-x-2 bg-white">
                    <div class="w-24 h-24 bg-zinc-50 rounded-2xl overflow-hidden flex items-center justify-center p-4">
                        <img src={product.img} class="w-full h-full object-contain group-hover:scale-110 transition-transform duration-700" alt={product.name} />
                    </div>
                    <div class="flex-1">
                        <p class="text-[8px] font-black tracking-[0.3em] text-[#e11d48] uppercase mb-2 opacity-60">{product.brand}</p>
                        <h5 class="text-xl font-bold tracking-tight mb-1 group-hover:text-[#e11d48] transition-colors text-zinc-900">{product.name}</h5>
                        <p class="text-[10px] text-zinc-400 font-bold uppercase tracking-widest">{product.type}</p>
                    </div>
                    <div class="text-right">
                        <p class="text-2xl font-black tracking-tighter mb-2 text-zinc-900">${product.price}</p>
                        <button class="text-[9px] font-black uppercase tracking-widest text-white bg-black px-6 py-2 rounded-full transform translate-y-2 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">Order Now</button>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<script is:inline>
    (function() {
        const init = () => {
            if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;
            const trigger = "#auto-catalog";
            ScrollTrigger.getAll().forEach(t => { if (t.trigger === trigger) t.kill(); });

            gsap.from(".catalog-label-auto", {
                scrollTrigger: { trigger: trigger, start: "top 90%" },
                opacity: 0, x: -30, duration: 1, ease: "power2.out"
            });
            gsap.from(".catalog-title-auto", {
                scrollTrigger: { trigger: trigger, start: "top 90%" },
                opacity: 0, y: 40, duration: 1.2, delay: 0.1, ease: "power4.out"
            });
            gsap.from(".catalog-item-auto", {
                scrollTrigger: { trigger: trigger, start: "top 80%" },
                opacity: 0, x: 60, duration: 1, stagger: 0.05, ease: "power3.out"
            });
        };
        if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', init); } else { init(); }
    })();
</script>
