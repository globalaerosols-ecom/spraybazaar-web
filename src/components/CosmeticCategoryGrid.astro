---
const categories = [
    {
        name: "Deodorant",
        tags: "Daily Hygiene • Freshness",
        image: "https://images.unsplash.com/photo-1620916566398-39f1143ab7be?auto=format&fit=crop&q=80&w=800",
        link: "/cosmetics/deodorant"
    },
    {
        name: "Fragrances",
        tags: "Signature • Body Sprays",
        image: "https://images.unsplash.com/photo-1541643600914-78b084683601?auto=format&fit=crop&q=80&w=800",
        link: "#"
    },
    {
        name: "Hair Care",
        tags: "Professional • Styling",
        image: "https://images.unsplash.com/photo-1527799822367-a233b47b0ee6?auto=format&fit=crop&q=80&w=800",
        link: "#"
    },
    {
        name: "Hair Colors",
        tags: "Vibrant • Temporary",
        image: "https://images.unsplash.com/photo-1634449571010-02389ed0f9b0?auto=format&fit=crop&q=80&w=800",
        link: "#"
    },
    {
        name: "Sunscreen Sprays",
        tags: "Protection • UV Guard",
        image: "https://images.unsplash.com/photo-1521223344201-d169129f7b7d?auto=format&fit=crop&q=80&w=800",
        link: "#"
    },
    {
        name: "Color Cosmetics",
        tags: "Makeup • Artistry",
        image: "https://images.unsplash.com/photo-1522335789203-aabd1fc54bc9?auto=format&fit=crop&q=80&w=800",
        link: "#"
    }
];
---

<section class="category-grid-section w-full px-6 lg:px-24 py-32 bg-white">
    <header class="category-header mb-20 flex flex-col md:flex-row justify-between items-end gap-8">
        <div class="title-wrapper">
            <span class="text-[#2b65ff] text-[10px] font-bold uppercase tracking-[0.4em] mb-4 block">Selection</span>
            <h2 id="category-main-title" class="text-5xl md:text-7xl font-black tracking-tighter leading-none">
                Shop by Category
            </h2>
        </div>
        <div class="category-info opacity-80 max-w-xs text-right hidden md:block">
            <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-400">
                Explore our specialized personal care collections engineered for performance.
            </p>
        </div>
    </header>

    <div class="category-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-10 gap-y-16">
        {categories.map((cat) => (
            <a href={cat.link} class="category-card group block no-underline text-inherit">
                <div class="image-wrapper relative aspect-[1/1] overflow-hidden rounded-[2rem] bg-zinc-100 mb-6">
                    <img 
                        src={cat.image} 
                        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" 
                        alt={cat.name}
                        loading="lazy"
                    />
                    <div class="absolute inset-0 flex items-center justify-center z-20">
                        <span class="category-shop-pill bg-[#2b65ff] text-white px-8 py-3 rounded-full text-xs font-black shadow-xl opacity-0 scale-75 group-hover:opacity-100 group-hover:scale-100 transition-all duration-300 uppercase tracking-widest">
                            Browse
                        </span>
                    </div>
                    <div class="absolute inset-0 bg-black/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                </div>
                <div class="card-meta">
                    <span class="category-tags block text-[9px] font-bold uppercase tracking-[0.2em] text-[#2b65ff] mb-2 opacity-60">
                        {cat.tags}
                    </span>
                    <h3 class="category-title text-3xl font-black tracking-tighter group-hover:opacity-60 transition-opacity">
                        {cat.name}
                    </h3>
                </div>
            </a>
        ))}
    </div>
</section>

<script is:inline>
    window.addEventListener('load', () => {
        if (typeof gsap === 'undefined' || typeof SplitType === 'undefined') return;

        // Header Animation
        const mainTitle = document.getElementById('category-main-title');
        const splitMainTitle = new SplitType(mainTitle, { types: 'chars' });
        
        gsap.set(splitMainTitle.chars, { y: 60, opacity: 0 });
        
        gsap.to(splitMainTitle.chars, {
            scrollTrigger: {
                trigger: '.category-header',
                start: 'top 90%'
            },
            y: 0,
            opacity: 1,
            stagger: 0.03,
            duration: 1,
            ease: "power4.out"
        });

        // Cards Animation (Elastic behavior matching Portfolio)
        const cards = document.querySelectorAll('.category-card');
        cards.forEach((card, i) => {
            const wrapper = card.querySelector('.image-wrapper');
            const img = card.querySelector('img');
            const tags = card.querySelector('.category-tags');
            const title = card.querySelector('.category-title');
            const splitTitle = new SplitType(title, { types: 'chars' });

            gsap.set(wrapper, { scale: 0.7, opacity: 0 });
            gsap.set(img, { scale: 1.3 });
            gsap.set(tags, { opacity: 0, y: 10 });
            gsap.set(splitTitle.chars, { opacity: 0, filter: "blur(10px)", y: 10 });

            const tl = gsap.timeline({
                scrollTrigger: {
                    trigger: card,
                    start: "top 90%",
                    toggleActions: "play none none reverse"
                }
            });

            tl.to(wrapper, { 
                scale: 1, 
                opacity: 1, 
                duration: 1.5, 
                ease: "elastic.out(1, 0.75)",
                force3D: true 
            })
            .to(img, { 
                scale: 1, 
                duration: 1.5, 
                ease: "power3.out",
                force3D: true 
            }, "<")
            .to(tags, { 
                opacity: 0.6, 
                y: 0, 
                duration: 0.8 
            }, "-=0.8")
            .to(splitTitle.chars, { 
                opacity: 1, 
                filter: "blur(0px)", 
                y: 0, 
                stagger: 0.02, 
                duration: 0.8 
            }, "-=0.7");
        });

        ScrollTrigger.refresh();
    });
</script>
