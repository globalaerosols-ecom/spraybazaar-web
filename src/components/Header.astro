---
---
<nav id="header-container" class="fixed top-6 left-0 w-full px-4 md:px-12 z-50 flex justify-between items-center pointer-events-none transition-all duration-300">
    <!-- Left Group: Logo + Links -->
    <div class="flex items-center gap-4 md:gap-8 pointer-events-auto">
        <a href="/" class="text-3xl md:text-5xl font-extrabold tracking-tighter text-[#2b65ff] hover:scale-105 transition-transform no-underline" style="font-family: 'Plus Jakarta Sans', sans-serif;">
            Spray Bazaar
        </a>
        
        <!-- Links Capsule -->
        <div class="hidden lg:flex items-center">
            <div class="flex items-center gap-1 glass-capsule px-2 py-1.5 rounded-full">
                <a href="/" class="nav-pill-btn active">Home</a>
                <a href="/products/bazaar-pro" class="nav-pill-btn">Products</a>
                <a href="/cosmetics" class="nav-pill-btn">Cosmetics</a>
                <a href="/industrial" class="nav-pill-btn">Industrial</a>
                <a href="/automotive" class="nav-pill-btn">Auto</a>
                <a href="/arts-and-crafts" class="nav-pill-btn">Arts</a>
                <a href="#" class="nav-pill-btn">About</a>
            </div>
        </div>
    </div>

    <!-- Right Action Items -->
    <div class="flex items-center gap-2 pointer-events-auto">
        <div class="glass-icon-btn">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" stroke-width="2.5"/></svg>
        </div>
        <div class="glass-icon-btn">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" stroke-width="2.5"/></svg>
        </div>
        <div class="glass-capsule flex items-center gap-2 px-4 py-2 relative group cursor-pointer">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" stroke-width="2.5"/></svg>
            <span class="text-[10px] font-bold">(0)</span>
        </div>
        <div class="hidden md:flex glass-capsule px-5 py-2 text-[10px] font-bold uppercase tracking-wider cursor-pointer">USD | EN</div>
        <button class="menu-btn lg:hidden glass-icon-btn">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M4 6h16M4 12h16M4 18h16" stroke-width="2.5"/></svg>
        </button>
    </div>

    <!-- Mobile Menu Overlay -->
    <div id="mobile-menu" class="ui-toggle fixed inset-0 bg-white/90 backdrop-blur-3xl z-[100] flex flex-col items-center justify-center gap-8 opacity-0 pointer-events-none transition-all duration-300">
        <button id="close-menu" class="absolute top-10 right-10 w-12 h-12 rounded-full bg-black/5 flex items-center justify-center">
            <svg class="w-6 h-6 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12" stroke-width="2.5"/></svg>
        </button>
        
        <div class="flex flex-col items-center gap-6">
            <a href="/" class="mobile-nav-link active">Home</a>
            <a href="/products/bazaar-pro" class="mobile-nav-link">Products</a>
            <a href="/cosmetics" class="mobile-nav-link">Cosmetics</a>
            <a href="/industrial" class="mobile-nav-link">Industrial</a>
            <a href="/automotive" class="mobile-nav-link">Automotive</a>
            <a href="/arts-and-crafts" class="mobile-nav-link">Arts & Crafts</a>
            <a href="#" class="mobile-nav-link">About Us</a>
        </div>

        <div class="mt-12 flex flex-col items-center gap-4">
            <button class="px-12 py-5 bg-[#2b65ff] text-white rounded-2xl text-[10px] font-black uppercase tracking-widest shadow-xl shadow-[#2b65ff]/20">Account Login</button>
            <p class="text-[9px] font-bold text-zinc-400 uppercase tracking-widest">USD • English (US)</p>
        </div>
    </div>
</nav>


<style>
    .glass-capsule {
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(24px) saturate(180%);
        -webkit-backdrop-filter: blur(24px) saturate(180%);
        border: 1px solid rgba(255, 255, 255, 0.3);
        color: white;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border-radius: 999px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    }
    .glass-capsule:hover {
        background: rgba(255, 255, 255, 0.25);
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
    }
    .glass-icon-btn {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(24px) saturate(180%);
        -webkit-backdrop-filter: blur(24px) saturate(180%);
        border: 1px solid rgba(255, 255, 255, 0.3);
        color: white;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    }
    .glass-icon-btn:hover {
        background: rgba(255, 255, 255, 0.25);
        transform: scale(1.05);
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
    }
    .nav-pill-btn {
        padding: 8px 16px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: white;
        opacity: 0.6;
        transition: all 0.2s;
        text-decoration: none;
        text-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
    }
    .nav-pill-btn:hover, .nav-pill-btn.active {
        opacity: 1;
        background: rgba(255, 255, 255, 0.2);
    }

    .mobile-nav-link {
        font-size: 2rem;
        font-weight: 900;
        letter-spacing: -0.05em;
        text-decoration: none;
        color: #121212;
        transition: all 0.3s;
        text-transform: uppercase;
    }
    .mobile-nav-link.active {
        color: #2b65ff;
    }
    .mobile-nav-link:hover {
        transform: scale(1.1);
        color: #2b65ff;
    }
</style>


<script is:inline>
    // Header scroll sync effect - Throttled for performance
    const capsules = document.querySelectorAll('.glass-capsule, .glass-icon-btn');
    const navLinks = document.querySelectorAll('.nav-pill-btn');
    let ticking = false;

    window.addEventListener('scroll', () => {
        if (!ticking) {
            window.requestAnimationFrame(() => {
                const isScrolled = window.scrollY > 50;
                
                capsules.forEach(cap => {
                    if (isScrolled) {
                        cap.style.background = 'rgba(255, 255, 255, 0.9)';
                        cap.style.borderColor = 'rgba(0, 0, 0, 0.05)';
                        cap.style.color = 'black';
                        cap.classList.add('shadow-2xl');
                    } else {
                        cap.style.background = 'rgba(255, 255, 255, 0.15)';
                        cap.style.borderColor = 'rgba(255, 255, 255, 0.3)';
                        cap.style.color = 'white';
                        cap.classList.remove('shadow-2xl');
                    }
                });

                navLinks.forEach(link => {
                    if (isScrolled) {
                        link.style.color = 'black';
                        link.style.textShadow = 'none';
                    } else {
                        link.style.color = 'white';
                        link.style.textShadow = '0 1px 2px rgba(0, 0, 0, 0.1)';
                    }
                });

                ticking = false;
            });
            ticking = true;
        }
    });

    // Mobile Menu Toggle
    const menuBtn = document.querySelector('.menu-btn');
    const closeBtn = document.getElementById('close-menu');
    const mobileMenu = document.getElementById('mobile-menu');

    if (menuBtn && closeBtn && mobileMenu) {
        const toggleMenu = (open) => {
            if (open) {
                mobileMenu.classList.remove('opacity-0', 'pointer-events-none');
                mobileMenu.classList.add('opacity-100', 'pointer-events-auto');
                document.body.style.overflow = 'hidden';
            } else {
                mobileMenu.classList.add('opacity-0', 'pointer-events-none');
                mobileMenu.classList.remove('opacity-100', 'pointer-events-auto');
                document.body.style.overflow = '';
            }
        };

        menuBtn.addEventListener('click', () => toggleMenu(true));
        closeBtn.addEventListener('click', () => toggleMenu(false));
        
        // Close on link click
        mobileMenu.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', () => toggleMenu(false));
        });
    }
</script>

