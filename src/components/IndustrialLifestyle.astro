---
---
<section class="industrial-lifestyle-section w-full py-24 bg-white overflow-hidden">
    <div class="px-6 lg:px-24 mb-16 text-center">
        <span class="text-[#2b65ff] text-[10px] font-black uppercase tracking-[0.4em] mb-4 block">Proven Performance</span>
        <h2 class="text-5xl md:text-7xl font-black tracking-tighter leading-none">AEROSOL <span class="text-[#2b65ff]">PERFORMANCE.</span></h2>
    </div>

    <div class="flex flex-col gap-4 px-4 md:px-12">
        <div class="lifestyle-item relative w-full aspect-[21/9] rounded-[2rem] md:rounded-[3rem] overflow-hidden group">
            <img 
                src="/images/industrial/lifestyle_1.png" 
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-[2s] ease-out group-hover:scale-105 lifestyle-img" 
                alt="Industrial mechanical work"
                loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
            <div class="absolute bottom-8 left-8 md:bottom-12 md:left-12 z-10 text-white opacity-0 transform translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-700 delay-100">
                <span class="text-[10px] font-bold uppercase tracking-widest block mb-2">Technical Environment</span>
                <h3 class="text-2xl md:text-4xl font-black tracking-tighter">MAXIMUM UPTIME.</h3>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="lifestyle-item relative aspect-[16/9] md:aspect-square lg:aspect-[16/9] rounded-[2rem] md:rounded-[3rem] overflow-hidden group">
                <img 
                    src="/images/industrial/lifestyle_2.png" 
                    class="absolute inset-0 w-full h-full object-cover transition-transform duration-[2s] ease-out group-hover:scale-105 lifestyle-img" 
                    alt="Welding and metal protection"
                    loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
                <div class="absolute bottom-8 left-8 z-10 text-white opacity-0 transform translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-700 delay-100">
                    <span class="text-[10px] font-bold uppercase tracking-widest block mb-2">Metal Fabrication</span>
                    <h3 class="text-2xl md:text-4xl font-black tracking-tighter">ZERO CORROSION.</h3>
                </div>
            </div>
            <div class="lifestyle-item relative aspect-[16/9] md:aspect-square lg:aspect-[16/9] rounded-[2rem] md:rounded-[3rem] overflow-hidden group">
                <img 
                    src="/images/industrial/lifestyle_3.png" 
                    class="absolute inset-0 w-full h-full object-cover transition-transform duration-[2s] ease-out group-hover:scale-105 lifestyle-img" 
                    alt="Precision engineering"
                    loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
                <div class="absolute bottom-8 left-8 z-10 text-white opacity-0 transform translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-700 delay-100">
                    <span class="text-[10px] font-bold uppercase tracking-widest block mb-2">Machinery Care</span>
                    <h3 class="text-2xl md:text-4xl font-black tracking-tighter">ENGINEERED FLOW.</h3>
                </div>
            </div>
        </div>
    </div>
</section>

<script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
        if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

        gsap.utils.toArray('.lifestyle-item').forEach((item) => {
            gsap.from(item, {
                scrollTrigger: {
                    trigger: item,
                    start: "top 85%",
                    toggleActions: "play none none reverse"
                },
                y: 50,
                opacity: 0,
                duration: 1.5,
                ease: "power4.out"
            });
        });
    });
</script>

<style>
    .lifestyle-item {
        background: #1a1a1a;
    }
</style>
