---
const reviews = [
    {
        author: "David W.",
        title: "Unrivaled Flow Control",
        body: "As a professional automotive refinisher, I've tried every brand. The Bazaar Pro series has a nozzle design that simply doesn't clog. The pressure stays consistent from the first spray to the last drop.",
        product: "Bazaar Pro Matte",
        rating: 5,
        date: "2 days ago"
    },
    {
        author: "Marcus T.",
        title: "Saves me hours",
        body: "The instant-dry formulation isn't a marketing gimmick—it actually works. I was able to handle my prototype within 10 minutes of the final coat. Flawless execution.",
        product: "Bazaar Pro Matte",
        rating: 5,
        date: "1 week ago"
    },
    {
        author: "Elena V.",
        title: "Deepest Matte Finish",
        body: "I was looking for a specific industrial matte look for my metal sculptures. This is it. No orange peel, no uneven sheen. Just pure, deep, uniform matte.",
        product: "Bazaar Pro Matte",
        rating: 5,
        date: "3 days ago"
    },
    {
        author: "Sarah L.",
        title: "Ergonomic Design",
        body: "The aluminum vessel is significantly lighter than standard cans. It makes a huge difference in hand fatigue during long application sessions. Truly professional grade.",
        product: "Bazaar Pro Matte",
        rating: 4,
        date: "2 weeks ago"
    }
];

const ratings = [
    { stars: 5, percentage: 94 },
    { stars: 4, percentage: 5 },
    { stars: 3, percentage: 1 },
    { stars: 2, percentage: 0 },
    { stars: 1, percentage: 0 }
];
---

<section class="reviews-section w-full py-32 bg-[#fafafa]" id="reviews">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-24">
        <!-- Review Header / Summary -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center mb-24">
            <div class="summary-container opacity-0 transform -translate-x-8">
                <span class="text-[#2b65ff] text-[10px] font-bold uppercase tracking-[0.4em] mb-4 block">Endorsements</span>
                <h2 class="text-5xl md:text-7xl font-black tracking-tighter leading-none mb-8">
                    Tested by <br/> <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#2b65ff] to-[#1a54ee]">Professionals.</span>
                </h2>
                <div class="flex items-center gap-6">
                    <div class="text-6xl font-black tracking-tighter">4.92</div>
                    <div>
                        <div class="flex text-[#2b65ff] mb-1">
                            {"★★★★★".split("").map(() => <span class="text-lg">★</span>)}
                        </div>
                        <p class="text-zinc-400 text-[10px] font-bold uppercase tracking-widest">Global user feedback</p>
                    </div>
                </div>
            </div>

            <div class="bars-container space-y-4 opacity-0 transform translate-x-8">
                {ratings.map((rating) => (
                    <div class="flex items-center gap-4 group">
                        <span class="text-[10px] font-bold w-12 text-zinc-400">{rating.stars} Stars</span>
                        <div class="flex-1 h-[2px] bg-zinc-200 relative overflow-hidden">
                            <div 
                                class="rating-bar-fill absolute inset-y-0 left-0 bg-[#2b65ff] transform -translate-x-full" 
                                data-percent={rating.percentage}
                            ></div>
                        </div>
                        <span class="text-[10px] font-bold w-8 text-right text-zinc-900">{rating.percentage}%</span>
                    </div>
                ))}
            </div>
        </div>

        <!-- Review Cards Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {reviews.map((review) => (
                <div class="review-card group bg-white p-10 rounded-2xl border border-zinc-100 transition-all duration-500 hover:shadow-2xl hover:shadow-black/[0.02] opacity-0 transform translate-y-12">
                    <div class="flex justify-between items-start mb-8">
                        <div>
                            <div class="flex text-[#2b65ff] mb-3">
                                {Array.from({ length: review.rating }).map(() => <span class="text-sm">★</span>)}
                            </div>
                            <span class="text-[9px] font-black tracking-[0.2em] text-[#2b65ff] uppercase block opacity-60">
                                {review.product}
                            </span>
                        </div>
                        <span class="text-[10px] font-bold text-zinc-300 uppercase tracking-widest">{review.date}</span>
                    </div>
                    
                    <h4 class="text-xl font-bold tracking-tight mb-4 group-hover:text-[#2b65ff] transition-colors duration-300">
                        "{review.title}"
                    </h4>
                    <p class="text-zinc-500 text-sm leading-relaxed mb-8 font-medium">
                        {review.body}
                    </p>
                    
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-full bg-zinc-100 flex items-center justify-center text-[10px] font-bold text-[#2b65ff]">
                            {review.author.charAt(0)}
                        </div>
                        <div>
                            <p class="text-[10px] font-black uppercase tracking-widest leading-none">{review.author}</p>
                            <p class="text-[8px] font-bold text-zinc-400 uppercase tracking-widest mt-1">Verified Professional</p>
                        </div>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<script is:inline>
    // Reuse animation logic safely
    document.addEventListener('DOMContentLoaded', () => {
        if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

        // Animate Header Summary
        gsap.to(".summary-container", {
            scrollTrigger: {
                trigger: "#reviews",
                start: "top 80%",
            },
            opacity: 1,
            x: 0,
            duration: 1.2,
            ease: "power4.out"
        });

        // Animate Rating Bars
        gsap.to(".bars-container", {
            scrollTrigger: {
                trigger: "#reviews",
                start: "top 80%",
            },
            opacity: 1,
            x: 0,
            duration: 1.2,
            ease: "power4.out",
            onComplete: () => {
                document.querySelectorAll(".rating-bar-fill").forEach(bar => {
                    gsap.to(bar, {
                        x: "0%",
                        duration: 1.5,
                        delay: 0.2,
                        ease: "power4.out",
                        width: bar.getAttribute('data-percent') + "%"
                    });
                });
            }
        });

        // Animate Review Cards
        gsap.to(".review-card", {
            scrollTrigger: {
                trigger: ".review-card",
                start: "top 90%",
            },
            opacity: 1,
            y: 0,
            duration: 1.2,
            stagger: 0.2,
            ease: "power4.out"
        });
    });
</script>

<style>
    .reviews-section {
        clip-path: inset(0 0 0 0);
    }
    .rating-bar-fill {
        width: 0%; /* Initial state */
    }
</style>
