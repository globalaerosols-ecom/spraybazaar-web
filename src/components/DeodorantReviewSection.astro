---
const reviews = [
    {
        author: "Sophie A.",
        title: "All-day freshness",
        body: "I've tried many luxury deodorants, but the Aqua Mist series is on another level. It stays fresh even after a long day at the studio. The scent is subtle and extremely premium.",
        product: "Aqua Mist Deodorant",
        rating: 5,
        date: "Today"
    },
    {
        author: "Julian M.",
        title: "No white marks, finally",
        body: "As someone who wears a lot of black, finding a high-performance deodorant that doesn't leave marks was impossible. Spray Bazaar's formulation is invisible and works better than anything from the drugstore.",
        product: "Carbon Black Sport",
        rating: 5,
        date: "3 days ago"
    },
    {
        author: "Isabella K.",
        title: "Worth every penny",
        body: "The packaging is stunning, but the performance is what sold me. The spray is so fine and dries instantly. Every scent in the collection feels curated and high-end.",
        product: "Ethereal Bloom",
        rating: 5,
        date: "1 week ago"
    },
    {
        author: "Liam H.",
        title: "Game changer for sensitive skin",
        body: "I usually react to aerosols, but this formulation is very gentle. No irritation at all, even with daily use. Highly recommend the Rosewood variant.",
        product: "Rosewood & Cedar",
        rating: 4,
        date: "2 weeks ago"
    }
];

const ratings = [
    { stars: 5, percentage: 88 },
    { stars: 4, percentage: 9 },
    { stars: 3, percentage: 2 },
    { stars: 2, percentage: 1 },
    { stars: 1, percentage: 0 }
];
---

<section class="reviews-section w-full py-32 bg-white" id="reviews-deodorant">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-24">
        <!-- Review Header / Summary -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center mb-24">
            <div class="summary-container-deo opacity-0 transform -translate-x-8">
                <span class="text-[#2b65ff] text-[10px] font-bold uppercase tracking-[0.4em] mb-4 block">The Verdict</span>
                <h2 class="text-5xl md:text-7xl font-black tracking-tighter leading-none mb-8">
                    Sophisticated <br/> <span class="text-transparent bg-clip-text bg-gradient-to-r from-zinc-900 to-zinc-500">Confidence.</span>
                </h2>
                <div class="flex items-center gap-6">
                    <div class="text-6xl font-black tracking-tighter">4.88</div>
                    <div>
                        <div class="flex text-[#2b65ff] mb-1">
                            {"★★★★★".split("").map(() => <span class="text-lg">★</span>)}
                        </div>
                        <p class="text-zinc-400 text-[10px] font-bold uppercase tracking-widest">Global collection ratings</p>
                    </div>
                </div>
            </div>

            <div class="bars-container-deo space-y-4 opacity-0 transform translate-x-8">
                {ratings.map((rating) => (
                    <div class="flex items-center gap-4 group">
                        <span class="text-[10px] font-bold w-12 text-zinc-400">{rating.stars} Stars</span>
                        <div class="flex-1 h-[2px] bg-zinc-100 relative overflow-hidden">
                            <div 
                                class="rating-bar-fill-deo absolute inset-y-0 left-0 bg-zinc-900 transform -translate-x-full" 
                                data-percent={rating.percentage}
                            ></div>
                        </div>
                        <span class="text-[10px] font-bold w-8 text-right text-zinc-900">{rating.percentage}%</span>
                    </div>
                ))}
            </div>
        </div>

        <!-- Review Cards Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {reviews.map((review) => (
                <div class="review-card-deo group bg-[#fcfcfd] p-10 rounded-2xl border border-zinc-100 transition-all duration-500 hover:shadow-2xl hover:shadow-black/[0.02] opacity-0 transform translate-y-12">
                    <div class="flex justify-between items-start mb-8">
                        <div>
                            <div class="flex text-[#2b65ff] mb-3">
                                {Array.from({ length: review.rating }).map(() => <span class="text-sm">★</span>)}
                            </div>
                            <span class="text-[9px] font-black tracking-[0.2em] text-zinc-900 uppercase block opacity-60">
                                {review.product}
                            </span>
                        </div>
                        <span class="text-[10px] font-bold text-zinc-300 uppercase tracking-widest">{review.date}</span>
                    </div>
                    
                    <h4 class="text-xl font-bold tracking-tight mb-4 group-hover:text-[#2b65ff] transition-colors duration-300">
                        "{review.title}"
                    </h4>
                    <p class="text-zinc-500 text-sm leading-relaxed mb-8 font-medium">
                        {review.body}
                    </p>
                    
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-full bg-zinc-900 flex items-center justify-center text-[10px] font-bold text-white">
                            {review.author.charAt(0)}
                        </div>
                        <div>
                            <p class="text-[10px] font-black uppercase tracking-widest leading-none text-zinc-900">{review.author}</p>
                            <p class="text-[8px] font-bold text-zinc-400 uppercase tracking-widest mt-1">Verified Buyer</p>
                        </div>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
        if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

        // Animate Header Summary
        gsap.to(".summary-container-deo", {
            scrollTrigger: {
                trigger: "#reviews-deodorant",
                start: "top 80%",
            },
            opacity: 1,
            x: 0,
            duration: 1.2,
            ease: "power4.out"
        });

        // Animate Rating Bars
        gsap.to(".bars-container-deo", {
            scrollTrigger: {
                trigger: "#reviews-deodorant",
                start: "top 80%",
            },
            opacity: 1,
            x: 0,
            duration: 1.2,
            ease: "power4.out",
            onComplete: () => {
                document.querySelectorAll(".rating-bar-fill-deo").forEach(bar => {
                    gsap.to(bar, {
                        x: "0%",
                        duration: 1.5,
                        delay: 0.2,
                        ease: "power4.out",
                        width: bar.getAttribute('data-percent') + "%"
                    });
                });
            }
        });

        // Animate Review Cards
        gsap.to(".review-card-deo", {
            scrollTrigger: {
                trigger: ".review-card-deo",
                start: "top 90%",
            },
            opacity: 1,
            y: 0,
            duration: 1.2,
            stagger: 0.2,
            ease: "power4.out"
        });
    });
</script>

<style>
    .reviews-section {
        clip-path: inset(0 0 0 0);
    }
    .rating-bar-fill-deo {
        width: 0%;
    }
</style>
