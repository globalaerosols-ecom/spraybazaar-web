---
const industrialListProducts = [
    { id: 16, name: "Silicone Release Spray", brand: "Aura", price: "18.00", img: "/images/industrial/catalog_silicone.png", type: "Molding" },
    { id: 17, name: "Anti-Seize Lubricant", brand: "Onyx", price: "24.00", img: "/images/industrial/catalog_antiseize.png", type: "Heavy Duty" },
    { id: 18, name: "Dry Graphite Spray", brand: "Zenith", price: "22.00", img: "/images/industrial/catalog_graphite.png", type: "Dry Lube" },
    { id: 19, name: "Rust Converter Aerosol", brand: "Vibe", price: "20.00", img: "/images/industrial/catalog_rustconverter.png", type: "Treatment" },
    { id: 20, name: "Leak Detector Spray", brand: "Aura", price: "15.00", img: "/images/industrial/catalog_leakdetector.png", type: "Safety" },
    { id: 21, name: "Degreaser Pro Mist", brand: "Onyx", price: "16.50", img: "/images/industrial/catalog_degreaser.png", type: "Cleaning" }
];
---
<section id="industrial-catalog" class="w-full py-32 bg-white relative overflow-hidden min-h-[600px]">
    <div class="px-6 lg:px-24 mb-20 flex flex-col md:flex-row justify-between items-end gap-8">
        <div class="header-left">
            <span class="catalog-label-ind text-[#2b65ff] text-[10px] font-black uppercase tracking-[0.4em] mb-4 block">Industrial Catalog</span>
            <h2 class="catalog-title-ind text-5xl md:text-7xl font-black tracking-tighter leading-none text-zinc-900">ELITE <span class="text-[#2b65ff]">INVENTORY.</span></h2>
        </div>
        <div class="hidden md:block header-right">
            <p class="catalog-desc-ind text-zinc-400 text-sm max-w-[250px] font-medium leading-relaxed">
                A comprehensive selection of professional-grade aerosol solutions for heavy-duty applications.
            </p>
        </div>
    </div>

    <div class="max-w-[1400px] mx-auto px-6 lg:px-24">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-2">
            {industrialListProducts.map((product) => (
                <div class="catalog-item-ind flex items-center gap-8 py-8 border-b border-zinc-100 hover:bg-[#fbfbfb] px-6 transition-all duration-500 group cursor-pointer rounded-xl hover:translate-x-2 bg-white">
                    <div class="w-24 h-24 bg-zinc-50 rounded-2xl overflow-hidden flex items-center justify-center p-4">
                        <img src={product.img} class="w-full h-full object-contain group-hover:scale-110 transition-transform duration-700" alt={product.name} />
                    </div>
                    <div class="flex-1">
                        <p class="text-[8px] font-black tracking-[0.3em] text-[#2b65ff] uppercase mb-2 opacity-60">{product.brand}</p>
                        <h5 class="text-xl font-bold tracking-tight mb-1 group-hover:text-[#2b65ff] transition-colors text-zinc-900">{product.name}</h5>
                        <p class="text-[10px] text-zinc-400 font-bold uppercase tracking-widest">{product.type}</p>
                    </div>
                    <div class="text-right">
                        <p class="text-2xl font-black tracking-tighter mb-2 text-zinc-900">${product.price}</p>
                        <button class="text-[9px] font-black uppercase tracking-widest text-white bg-black px-6 py-2 rounded-full transform translate-y-2 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">Order Now</button>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<script is:inline>
    (function() {
        const init = () => {
            if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') {
                console.warn('GSAP/ScrollTrigger missing');
                return;
            }

            const trigger = "#industrial-catalog";
            
            // Kill any existing triggers for this section to prevent clashing
            ScrollTrigger.getAll().forEach(t => {
                if (t.trigger === trigger) t.kill();
            });

            gsap.from(".catalog-label-ind", {
                scrollTrigger: { trigger: trigger, start: "top 90%" },
                opacity: 0, x: -30, duration: 1, ease: "power2.out"
            });

            gsap.from(".catalog-title-ind", {
                scrollTrigger: { trigger: trigger, start: "top 90%" },
                opacity: 0, y: 40, duration: 1.2, delay: 0.1, ease: "power4.out"
            });

            gsap.from(".catalog-item-ind", {
                scrollTrigger: { trigger: trigger, start: "top 80%" },
                opacity: 0, x: 60, duration: 1, stagger: 0.05, ease: "power3.out"
            });
        };

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', init);
        } else {
            init();
        }
    })();
</script>
