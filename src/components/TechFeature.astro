---
---
<section class="max-w-[95%] mx-auto px-6 lg:px-16 py-24 md:py-32 bg-white text-zinc-900">
    
    <!-- Top Header Text -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16 md:mb-24 items-start">
        <div class="reveal-cinema">
            <p class="text-[10px] font-bold uppercase tracking-[0.3em] text-zinc-400">100% Waterproof, Guaranteed</p>
        </div>
        <div class="reveal-cinema">
            <h2 class="text-xl md:text-2xl font-medium leading-relaxed max-w-lg cinema-title">
                Our patented <span class="font-bold text-black text-shadow-sm">Bazaar-tex™ technology</span> is a material engineered with 4 soft and flexible layers that combine to keep you dry and comfortable all day long.
            </h2>
        </div>
    </div>

    <!-- Interactive Image Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-4 lg:gap-12 mb-24">
        
        <!-- Main Vertical Image (Left) -->
        <div class="image-container-jelly aspect-[3/4] md:aspect-auto md:h-[800px]">
            <img src="https://images.unsplash.com/photo-1549490349-8643362247b5?q=80&w=1000&auto=format&fit=crop" 
                 onerror="this.src='https://images.unsplash.com/photo-1541185933-ef5d8ed016c2?q=80&w=1000&auto=format&fit=crop'"
                 alt="Waterproof testing"
                 class="w-full h-full object-cover"
                 loading="lazy">
            
            <!-- Hotspot 1 -->
            <div class="absolute bottom-12 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3 w-full px-6 max-w-xs hotspot-area">
                <div class="glass-tooltip p-4 w-full">
                    <div class="flex items-center gap-2 mb-1">
                        <svg class="w-4 h-4 text-[#2b65ff]" fill="currentColor" viewBox="0 0 20 20"><path d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/></svg>
                        <span class="text-[10px] font-bold uppercase tracking-widest text-black">Fully Waterproof</span>
                    </div>
                    <p class="text-[11px] leading-relaxed text-zinc-600">
                        Aura-tex™ technology keeps water out while letting heat and sweat escape.
                    </p>
                </div>
                <div class="hotspot-btn">
                    <div class="w-2 h-2 bg-black rounded-full"></div>
                </div>
            </div>
        </div>

        <!-- Side Images (Right Stack) -->
        <div class="flex flex-col gap-4 lg:gap-6">
            
            <!-- Top Right Image -->
            <div class="image-container-jelly aspect-[16/10]">
                <img src="https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?q=80&w=1000&auto=format&fit=crop" 
                     onerror="this.src='https://images.unsplash.com/photo-1581090464777-f3220bbe1b8b?q=80&w=1000&auto=format&fit=crop'"
                     alt="Easy clean shell"
                     class="w-full h-full object-cover"
                     loading="lazy">
                
                <!-- Hotspot 2 -->
                <div class="absolute bottom-8 right-8 flex flex-col items-end gap-3 w-full px-6 max-w-xs hotspot-area">
                    <div class="glass-tooltip p-4 w-full">
                        <div class="flex items-center gap-2 mb-1">
                            <svg class="w-4 h-4 text-[#2b65ff]" fill="currentColor" viewBox="24 24"><path d="M12 3v19M5 8h14M5 16h14" stroke="currentColor" stroke-width="2"/></svg>
                            <span class="text-[10px] font-bold uppercase tracking-widest text-black">Easy to Clean Shell</span>
                        </div>
                        <p class="text-[11px] leading-relaxed text-zinc-600">
                            Translucent protective overlays offer enhanced durability and easier cleaning.
                        </p>
                    </div>
                    <div class="hotspot-btn">
                        <div class="w-2 h-2 bg-black rounded-full"></div>
                    </div>
                </div>
            </div>

            <!-- Bottom Right Image -->
            <div class="image-container-jelly aspect-[16/10]">
                <img src="https://images.unsplash.com/photo-1525909002-1b05e0c869d8?q=80&w=1000&auto=format&fit=crop" 
                     onerror="this.src='https://images.unsplash.com/photo-1505118380757-91f5f5632de0?q=80&w=1000&auto=format&fit=crop'"
                     alt="Premium details"
                     class="w-full h-full object-cover"
                     loading="lazy">
                
                <!-- Hotspot 3 -->
                <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3 w-full px-6 max-w-xs hotspot-area">
                    <div class="glass-tooltip p-4 w-full">
                        <div class="flex items-center gap-2 mb-1">
                            <svg class="w-4 h-4 text-[#2b65ff]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2z" stroke-width="2"/></svg>
                            <span class="text-[10px] font-bold uppercase tracking-widest text-black">Advanced Formulation</span>
                        </div>
                        <p class="text-[11px] leading-relaxed text-zinc-600">
                            Precision-engineered spray technology for a uniform, tailored application every time.
                        </p>
                    </div>
                    <div class="hotspot-btn">
                        <div class="w-2 h-2 bg-black rounded-full"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer Icon Bar -->
    <div class="text-center">
        <p class="text-[10px] font-bold uppercase tracking-[0.4em] text-zinc-400 mb-12 reveal-cinema">Every Single Spray Bazaar Product is</p>
        
        <div class="flex flex-wrap justify-center gap-8 md:gap-16 items-center reveal-icons">
            <div class="flex items-center gap-3 feature-item">
                <svg class="feature-icon text-zinc-800" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.051.046M8 10a2 2 0 012 2v2m4-2a2 2 0 012 2v2" stroke-width="1.5" stroke-linecap="round"/></svg>
                <span class="text-sm font-medium">Waterproof</span>
            </div>
            <div class="flex items-center gap-3 feature-item">
                <svg class="feature-icon text-zinc-800" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z" stroke-width="1.5" stroke-linecap="round"/></svg>
                <span class="text-sm font-medium">Lightweight</span>
            </div>
            <div class="flex items-center gap-3 feature-item">
                <svg class="feature-icon text-zinc-800" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" stroke-width="1.5" stroke-linecap="round"/></svg>
                <span class="text-sm font-medium">Breathable</span>
            </div>
            <div class="flex items-center gap-3 feature-item">
                <svg class="feature-icon text-zinc-800" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" stroke-width="1.5" stroke-linecap="round"/></svg>
                <span class="text-sm font-medium">Vegan</span>
            </div>
            <div class="flex items-center gap-3 feature-item">
                <svg class="feature-icon text-zinc-800" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" stroke-width="1.5" stroke-linecap="round"/></svg>
                <span class="text-sm font-medium">PFAS-free</span>
            </div>
        </div>
    </div>

</section>

<style>
    .glass-tooltip {
        background: rgba(255, 255, 255, 0.4);
        backdrop-filter: blur(12px) saturate(160%);
        -webkit-backdrop-filter: blur(12px) saturate(160%);
        border: 1px solid rgba(255, 255, 255, 0.5);
        border-radius: 12px;
        box-shadow: 0 4px 30px rgba(0, 0, 0, 0.05);
        opacity: 0;
        transform: translateY(10px);
        transition: all 0.4s ease;
        pointer-events: none;
    }

    .hotspot-area:hover .glass-tooltip {
        opacity: 1;
        transform: translateY(0);
    }

    .hotspot-btn {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.5);
        backdrop-filter: blur(4px);
        border: 1px solid rgba(255, 255, 255, 0.8);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .hotspot-btn:hover {
        transform: scale(1.2);
        background: rgba(255, 255, 255, 0.9);
    }

    .image-container-jelly {
        border-radius: 24px;
        overflow: hidden;
        position: relative;
        background-color: #f3f4f6;
        will-change: transform, opacity;
    }

    .feature-icon {
        width: 24px;
        height: 24px;
        opacity: 0.8;
    }
</style>

<script is:inline>
    // Ensure GSAP and SplitType are loaded
    window.addEventListener('load', () => {
        if (typeof gsap === 'undefined' || typeof SplitType === 'undefined') return;

        gsap.registerPlugin(ScrollTrigger);

        // 1. Dreamy Blur Text (Title and reveal-cinema)
        const revealTargets = document.querySelectorAll('.reveal-cinema, .cinema-title');
        
        revealTargets.forEach(target => {
            const split = new SplitType(target, { types: 'chars,lines' });
            
            gsap.set(split.chars, { 
                opacity: 0, 
                filter: "blur(12px)", 
                y: 15 
            });

            gsap.to(split.chars, {
                opacity: 1,
                filter: "blur(0px)",
                y: 0,
                duration: 1.2,
                stagger: 0.03,
                ease: "power2.out",
                scrollTrigger: {
                    trigger: target,
                    start: "top 90%",
                    toggleActions: "play none none reverse"
                }
            });
        });

        // 2. Jelly Pop for Images
        const jellyImages = document.querySelectorAll('.image-container-jelly');
        
        jellyImages.forEach(container => {
            const img = container.querySelector('img');
            
            // Set initial state
            gsap.set(container, { scale: 0.7, opacity: 0 });
            gsap.set(img, { scale: 1.3 });

            const tl = gsap.timeline({
                scrollTrigger: {
                    trigger: container,
                    start: "top 85%",
                    toggleActions: "play none none reverse"
                }
            });

            tl.to(container, { 
                scale: 1, 
                opacity: 1, 
                duration: 1.6, 
                ease: "elastic.out(1, 0.7)",
                force3D: true 
            })
            .to(img, { 
                scale: 1, 
                duration: 1.6, 
                ease: "power3.out",
                force3D: true 
            }, "<");
        });

        // 3. Staggered Feature Icons
        gsap.from(".feature-item", {
            y: 30,
            opacity: 0,
            duration: 1,
            stagger: 0.15,
            ease: "power3.out",
            scrollTrigger: {
                trigger: ".reveal-icons",
                start: "top 95%",
            }
        });
    });
</script>
