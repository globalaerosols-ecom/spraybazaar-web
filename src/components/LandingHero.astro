---
---
<section class="landing-hero-grid relative w-full bg-white overflow-hidden">
    <!-- Row 1: Split Hero (2 Columns) -->
    <div class="hero-row-1 flex flex-col md:flex-row h-screen">
        <!-- Left Side: Female / Light -->
        <div class="relative w-full md:w-1/2 h-1/2 md:h-full overflow-hidden group border-b md:border-b-0 md:border-r border-zinc-100">
            <div class="hero-main-img absolute inset-0 transition-transform duration-[3s] ease-out group-hover:scale-110">
                <img src="/images/landing/hero-female.png" class="w-full h-full object-cover" alt="Elite Female Care">
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-white/90 via-white/10 to-transparent z-10"></div>
            <div class="absolute bottom-16 left-0 w-full flex flex-col items-center justify-center z-20 split-content-left opacity-0 transform translate-y-8 px-12 text-center">
                <span class="text-[#2b65ff] text-[10px] font-black uppercase tracking-[0.4em] mb-4 block">Essentials</span>
                <h2 class="text-4xl md:text-6xl font-black tracking-tighter leading-tight mb-8">
                    AURA <br/> RADIANCE.
                </h2>
                <button class="px-12 py-5 bg-white text-black text-[10px] font-black uppercase tracking-widest hover:bg-[#2b65ff] hover:text-white transition-all shadow-xl">
                    Shop Now
                </button>
            </div>
        </div>

        <!-- Right Side: Male / Dark -->
        <div class="relative w-full md:w-1/2 h-1/2 md:h-full overflow-hidden group">
            <div class="hero-main-img absolute inset-0 transition-transform duration-[3s] ease-out group-hover:scale-110">
                <img src="/images/landing/hero-male.png" class="w-full h-full object-cover" alt="Professional Male Series">
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent z-10"></div>
            <div class="absolute bottom-16 left-0 w-full flex flex-col items-center justify-center z-20 split-content-right opacity-0 transform translate-y-8 px-12 text-center">
                <span class="text-[#2b65ff] text-[10px] font-black uppercase tracking-[0.4em] mb-4 block text-white/60">Professional</span>
                <h2 class="text-4xl md:text-6xl font-black tracking-tighter leading-tight mb-8 text-white">
                    ONYX <br/> PRECISION.
                </h2>
                <button class="px-12 py-5 bg-white text-black text-[10px] font-black uppercase tracking-widest hover:bg-[#2b65ff] hover:text-white transition-all shadow-xl">
                    Shop Now
                </button>
            </div>
        </div>
    </div>

    <!-- Row 2: Triple Grid Parallax Reveal -->
    <section class="triple-reveal-section w-full h-[90vh] bg-white overflow-hidden relative flex items-center justify-center">
        <div class="triple-reveal-container w-full h-full overflow-hidden">
            <div class="grid grid-cols-1 md:grid-cols-3 w-full h-full">

                <!-- Hair Care -->
                <div class="relative overflow-hidden group border-r border-zinc-100">
                    <img src="/images/landing/hero-hair.png"
                        class="triple-img absolute inset-0 w-full h-[130%] object-cover -top-[15%]"
                        alt="Hair Care">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent z-10"></div>
                    <div class="absolute bottom-0 left-0 w-full p-12 z-20">
                        <h3 class="triple-title text-white text-3xl font-black tracking-tighter mb-6">HAIR SERIES</h3>
                        <div class="triple-cta flex items-center gap-6">
                            <button class="px-8 py-4 bg-white text-black text-[10px] font-black uppercase tracking-widest hover:bg-[#2b65ff] hover:text-white transition-all shadow-2xl">
                                Buy Now
                            </button>
                            <button class="text-white text-[9px] font-black uppercase tracking-[0.3em] border-b border-white/40 pb-1 hover:border-white transition-all">Details</button>
                        </div>
                    </div>
                </div>

                <!-- Kitchen Care -->
                <div class="relative overflow-hidden group border-r border-zinc-100">
                    <img src="/images/landing/hero-kitchen.png"
                        class="triple-img absolute inset-0 w-full h-[130%] object-cover -top-[15%]"
                        alt="Kitchen Care">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent z-10"></div>
                    <div class="absolute bottom-0 left-0 w-full p-12 z-20">
                        <h3 class="triple-title text-white text-3xl font-black tracking-tighter mb-6">KITCHEN PRO</h3>
                        <div class="triple-cta flex items-center gap-6">
                            <button class="px-8 py-4 bg-white text-black text-[10px] font-black uppercase tracking-widest hover:bg-[#2b65ff] hover:text-white transition-all shadow-2xl">
                                Buy Now
                            </button>
                            <button class="text-white text-[9px] font-black uppercase tracking-[0.3em] border-b border-white/40 pb-1 hover:border-white transition-all">Details</button>
                        </div>
                    </div>
                </div>

                <!-- Spray Paint -->
                <div class="relative overflow-hidden group">
                    <img src="/images/landing/hero-paint.png"
                        class="triple-img absolute inset-0 w-full h-[130%] object-cover -top-[15%]"
                        alt="Spray Paint">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent z-10"></div>
                    <div class="absolute bottom-0 left-0 w-full p-12 z-20">
                        <h3 class="triple-title text-white text-3xl font-black tracking-tighter mb-6">COLOR BLAST</h3>
                        <div class="triple-cta flex items-center gap-6">
                            <button class="px-8 py-4 bg-white text-black text-[10px] font-black uppercase tracking-widest hover:bg-[#2b65ff] hover:text-white transition-all shadow-2xl">
                                Buy Now
                            </button>
                            <button class="text-white text-[9px] font-black uppercase tracking-[0.3em] border-b border-white/40 pb-1 hover:border-white transition-all">Details</button>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- Brand Label (Floating) -->
    <div class="absolute top-24 left-1/2 -translate-x-1/2 z-40 w-full text-center px-6 hero-brand-label opacity-0 pointer-events-none">
        <span class="text-[11px] font-black uppercase tracking-[1.5em] text-white mix-blend-difference">Spray Bazaar Professional</span>
    </div>
</section>

<script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
        if (typeof gsap === 'undefined') return;

        // ── Row 1 entry animations ──────────────────────────────────────────
        const heroTl = gsap.timeline();
        heroTl.to(".hero-brand-label", { opacity: 1, duration: 1.5, ease: "power2.out" })
              .to(".split-content-left, .split-content-right", {
                  opacity: 1, y: 0, duration: 1.2, stagger: 0.2, ease: "power4.out"
              }, "-=1.0");

        gsap.set(".hero-main-img", { scale: 1.1 });
        gsap.from(".hero-main-img", {
            scale: 1.6, duration: 2.5, ease: "power4.out", stagger: 0.1, force3D: true
        });

        // subtle drift on row-1 images only
        gsap.to(".hero-main-img", {
            x: -20, duration: 20, repeat: -1, yoyo: true, ease: "sine.inOut"
        });

        // ── Triple Grid: Parallax Reveal ────────────────────────────────────
        if (typeof ScrollTrigger !== 'undefined') {
            // Container expansion (same as product-trial reveal)
            gsap.from(".triple-reveal-container", {
                scrollTrigger: {
                    trigger: ".triple-reveal-section",
                    start: "top 100%",
                    end: "center center",
                    scrub: true
                },
                scale: 0.9,
                borderRadius: "15rem",
                width: "80%",
                height: "80vh",
                ease: "none"
            });

            // Inner parallax on the images
            gsap.to(".triple-img", {
                scrollTrigger: {
                    trigger: ".triple-reveal-section",
                    start: "top bottom",
                    end: "bottom top",
                    scrub: true
                },
                y: "25%",
                ease: "none"
            });

            // Premium title reveal: words rise from a clip mask
            if (typeof SplitType !== 'undefined') {
                const tripleTitles = document.querySelectorAll('.triple-title');
                tripleTitles.forEach((title, i) => {
                    const split = new SplitType(title, { types: 'words' });
                    // Wrap each word in a clip container
                    split.words.forEach(word => {
                        const wrapper = document.createElement('span');
                        wrapper.style.cssText = 'display:inline-block; overflow:hidden; vertical-align:bottom;';
                        word.parentNode.insertBefore(wrapper, word);
                        wrapper.appendChild(word);
                    });
                    gsap.from(split.words, {
                        scrollTrigger: {
                            trigger: '.triple-reveal-section',
                            start: 'top 30%',
                            toggleActions: 'play none none reverse'
                        },
                        y: '110%',
                        opacity: 0,
                        stagger: 0.08,
                        duration: 1.1,
                        delay: i * 0.1,
                        ease: 'expo.out'
                    });
                });
            }

            // Premium CTA: blur-to-focus fade
            gsap.from(".triple-cta", {
                scrollTrigger: {
                    trigger: '.triple-reveal-section',
                    start: 'top 25%',
                    toggleActions: 'play none none reverse'
                },
                opacity: 0,
                filter: 'blur(8px)',
                y: 16,
                stagger: 0.12,
                duration: 1.2,
                delay: 0.5,
                ease: 'power2.out'
            });
        }
    });
</script>

<style>
    .landing-hero-grid {
        background-color: #fff;
    }
</style>
