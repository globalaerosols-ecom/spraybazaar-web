---
const artsListProducts = [
    { id: 31, name: "Fluorescent Pink Spray", brand: "Aura", price: "14.00", img: "https://images.unsplash.com/photo-1541675154750-0444c7d51e8e?fm=webp&w=800&q=70&fit=crop", type: "Vibrant" },
    { id: 32, name: "Gold Leaf Effect", brand: "Aura", price: "22.00", img: "https://images.unsplash.com/photo-1590593162211-f9827b79ad07?fm=webp&w=800&q=70&fit=crop", type: "Metallic" },
    { id: 33, name: "Matte Clear Varnish", brand: "Aura", price: "15.00", img: "https://images.unsplash.com/photo-1525909002-1b05e0c869d8?fm=webp&w=800&q=70&fit=crop", type: "Finishing" },
    { id: 34, name: "Stripe Painting Mist", brand: "Aura", price: "12.50", img: "https://images.unsplash.com/photo-1513364776144-60967b0f800f?fm=webp&w=800&q=70&fit=crop", type: "Precision" },
    { id: 35, name: "Glitter Silver Spray", brand: "Aura", price: "18.00", img: "https://images.unsplash.com/photo-1579783902614-a3fb3927b6a5?fm=webp&w=800&q=70&fit=crop", type: "Sparkle" },
    { id: 36, name: "Texture Stone Effect", brand: "Aura", price: "19.50", img: "https://images.unsplash.com/photo-1582201942988-13e60e4556ee?fm=webp&w=800&q=70&fit=crop", type: "Structure" }
];
---
<section id="arts-catalog" class="w-full py-32 bg-white relative overflow-hidden min-h-[600px]">
    <div class="px-6 lg:px-24 mb-20 flex flex-col md:flex-row justify-between items-end gap-8">
        <div>
            <span class="catalog-label-arts text-[#f15a24] text-[10px] font-black uppercase tracking-[0.4em] mb-4 block">Creative Catalog</span>
            <h2 class="catalog-title-arts text-5xl md:text-7xl font-black tracking-tighter leading-none text-zinc-900">ARTISTIC <span class="text-[#f15a24]">PALETTE.</span></h2>
        </div>
        <div class="hidden md:block">
            <p class="catalog-desc-arts text-zinc-400 text-sm max-w-[250px] font-medium leading-relaxed">
                Unleash your creativity with our premium range of special effect and craft aerosols.
            </p>
        </div>
    </div>

    <div class="max-w-[1400px] mx-auto px-6 lg:px-24">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-2">
            {artsListProducts.map((product) => (
                <div class="catalog-item-arts flex items-center gap-8 py-8 border-b border-zinc-100 hover:bg-[#fbfbfb] px-6 transition-all duration-500 group cursor-pointer rounded-xl hover:translate-x-2 bg-white">
                    <div class="w-24 h-24 bg-zinc-50 rounded-2xl overflow-hidden flex items-center justify-center p-4">
                        <img src={product.img} class="w-full h-full object-contain group-hover:scale-110 transition-transform duration-700" alt={product.name} />
                    </div>
                    <div class="flex-1">
                        <p class="text-[8px] font-black tracking-[0.3em] text-[#f15a24] uppercase mb-2 opacity-60">{product.brand}</p>
                        <h5 class="text-xl font-bold tracking-tight mb-1 group-hover:text-[#f15a24] transition-colors text-zinc-900">{product.name}</h5>
                        <p class="text-[10px] text-zinc-400 font-bold uppercase tracking-widest">{product.type}</p>
                    </div>
                    <div class="text-right">
                        <p class="text-2xl font-black tracking-tighter mb-2 text-zinc-900">${product.price}</p>
                        <button class="text-[9px] font-black uppercase tracking-widest text-white bg-black px-6 py-2 rounded-full transform translate-y-2 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">Order Now</button>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<script is:inline>
    (function() {
        const init = () => {
            if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;
            const trigger = "#arts-catalog";
            ScrollTrigger.getAll().forEach(t => { if (t.trigger === trigger) t.kill(); });

            gsap.from(".catalog-label-arts", {
                scrollTrigger: { trigger: trigger, start: "top 90%" },
                opacity: 0, x: -30, duration: 1, ease: "power2.out"
            });
            gsap.from(".catalog-title-arts", {
                scrollTrigger: { trigger: trigger, start: "top 90%" },
                opacity: 0, y: 40, duration: 1.2, delay: 0.1, ease: "power4.out"
            });
            gsap.from(".catalog-item-arts", {
                scrollTrigger: { trigger: trigger, start: "top 80%" },
                opacity: 0, x: 60, duration: 1, stagger: 0.05, ease: "power3.out"
            });
        };
        if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', init); } else { init(); }
    })();
</script>
