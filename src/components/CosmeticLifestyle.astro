---
---
<section class="lifestyle-section relative w-full h-[70vh] md:h-[90vh] overflow-hidden bg-black flex items-center justify-center">
    <!-- Background Image with Parallax container -->
    <div class="absolute inset-0 z-0 scale-110">
        <img 
            src="/images/cosmetics/lifestyle-blonde.png" 
            class="w-full h-full object-cover opacity-80 lifestyle-parallax" 
            alt="Luxury Lifestyle"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-black/20"></div>
    </div>
    
    <!-- Floating Content Overlay -->
    <div class="relative z-10 text-center px-6 lifestyle-text-content opacity-0 transform translate-y-12">
        <div class="inline-block px-4 py-1 rounded-full border border-white/20 backdrop-blur-md bg-white/5 mb-6">
            <span class="text-white text-[9px] font-bold uppercase tracking-[0.4em]">Personal Care & Cosmetics</span>
        </div>
        <h2 class="text-white text-5xl md:text-8xl font-black tracking-tighter leading-[0.9] drop-shadow-2xl mb-8">
            DEFINITION OF <br/> <span class="text-transparent bg-clip-text bg-gradient-to-r from-white via-white/80 to-white/40">PURE LUXURY.</span>
        </h2>
        <div class="w-20 h-[2px] bg-[#2b65ff] mx-auto mb-8"></div>
        <p class="text-white/60 text-sm md:text-base max-w-lg mx-auto font-medium leading-relaxed">
            Experience the pinnacle of aerosol technology blended with world-class cosmetic formulations. Designed for those who demand uncompromising quality.
        </p>
    </div>

    <!-- Decorative Elements -->
    <div class="absolute bottom-12 left-12 z-20 hidden md:block">
        <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-full border border-white/20 flex items-center justify-center">
                <span class="text-white text-[10px] font-bold">2026</span>
            </div>
            <span class="text-white/40 text-[9px] font-bold uppercase tracking-widest">Global Series</span>
        </div>
    </div>
</section>

<script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
        if (typeof gsap === 'undefined') return;

        // Animate text content on scroll
        gsap.to(".lifestyle-text-content", {
            scrollTrigger: {
                trigger: ".lifestyle-section",
                start: "top 60%",
            },
            opacity: 1,
            y: 0,
            duration: 1.8,
            ease: "power4.out"
        });

        // Sophisticated Parallax effect for the image
        gsap.to(".lifestyle-parallax", {
            scrollTrigger: {
                trigger: ".lifestyle-section",
                start: "top bottom",
                end: "bottom top",
                scrub: 0.5
            },
            y: -150,
            ease: "none"
        });
    });
</script>

<style>
    .lifestyle-section {
        /* Ensure it covers the edges correctly during parallax */
        clip-path: inset(0 0 0 0);
    }
    .lifestyle-parallax {
        will-change: transform;
    }
</style>
