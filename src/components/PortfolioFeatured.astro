---
---
<section class="portfolio-section w-full px-6 lg:px-12 py-24 bg-[#F6F6FA] text-[#111]">
    <header class="portfolio-header max-w-[1600px] mx-auto flex flex-col md:flex-row justify-between items-start mb-24 gap-8">
        <div class="title-container">
            <h1 class="main-title text-5xl md:text-7xl lg:text-8xl font-black tracking-tighter leading-none whitespace-normal md:whitespace-nowrap" id="portfolio-title">
                Shop by Category
            </h1>
        </div>
        <div class="header-controls opacity-0 translate-y-8 flex flex-col items-start md:items-end max-w-xs pt-4">
            <div class="header-desc text-[10px] font-bold uppercase tracking-widest mb-6 opacity-60">
                <p>Explore our premium range of <br/> aerosol sprays by application.</p>
            </div>
            <div class="nav-buttons flex gap-3">
                <a href="#" class="btn-cinema bg-black text-white px-8 py-3 rounded-full text-xs font-bold uppercase tracking-widest hover:scale-105 transition-transform">Contact</a>
                <a href="#" class="btn-cinema bg-white border border-zinc-200 text-black px-8 py-3 rounded-full text-xs font-bold uppercase tracking-widest hover:scale-105 transition-transform">Catalog</a>
            </div>
        </div>
    </header>

    <div class="project-grid max-w-[1600px] mx-auto grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-20">
        <!-- Project 1: Cosmetics -->
        <a href="/cosmetics/deodorant" class="project-card group no-underline text-inherit block">
            <div class="image-wrapper-cinema relative aspect-[16/10] overflow-hidden rounded-3xl bg-zinc-200 mb-6">
                <img src="/images/cosmetics/category-cosmetics.png" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" alt="Personal Care & Cosmetics" loading="lazy">
                <div class="absolute inset-0 flex items-center justify-center z-50">
                    <span class="category-pill bg-[#2b65ff] text-white px-12 py-5 rounded-full text-lg font-black shadow-2xl hover:scale-110 transition-transform duration-300 uppercase tracking-wider">Shop Now</span>
                </div>
            </div>
            <div class="card-details">
                <span class="tags-cinema block text-[9px] font-bold uppercase tracking-[0.2em] text-zinc-400 mb-2">Luxury • Beauty • Daily Care</span>
                <h2 class="project-title-cinema text-2xl md:text-5xl font-light tracking-tight group-hover:opacity-60 transition-opacity">Personal Care & Cosmetics</h2>
            </div>
        </a>

        <!-- Project 2: Paints -->
        <a href="/industrial/spray-paints" class="project-card group no-underline text-inherit block">
            <div class="image-wrapper-cinema relative aspect-[16/10] overflow-hidden rounded-3xl bg-zinc-200 mb-6">
                <img src="/images/paints/paint-lifestyle-mural.png" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" alt="Paints & Coatings" loading="lazy">
                <div class="absolute inset-0 flex items-center justify-center z-50">
                    <span class="category-pill bg-[#2b65ff] text-white px-12 py-5 rounded-full text-lg font-black shadow-2xl hover:scale-110 transition-transform duration-300 uppercase tracking-wider">Shop Now</span>
                </div>
            </div>
            <div class="card-details">
                <span class="tags-cinema block text-[9px] font-bold uppercase tracking-[0.2em] text-zinc-400 mb-2">Artistic • Industrial • Coatings</span>
                <h2 class="project-title-cinema text-2xl md:text-5xl font-light tracking-tight group-hover:opacity-60 transition-opacity">Paints & Coatings</h2>
            </div>
        </a>

        <!-- Project 3: Industrial -->
        <a href="/industrial" class="project-card group no-underline text-inherit block">
            <div class="image-wrapper-cinema relative aspect-[16/10] overflow-hidden rounded-3xl bg-zinc-200 mb-6">
                <img src="https://images.unsplash.com/photo-1595152244561-39693d8aa531?fm=webp&w=800&q=70&fit=crop" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" alt="Industrial Pro" loading="lazy">
                <div class="absolute inset-0 flex items-center justify-center z-50">
                    <span class="category-pill bg-[#2b65ff] text-white px-12 py-5 rounded-full text-lg font-black shadow-2xl hover:scale-110 transition-transform duration-300 uppercase tracking-wider">Shop Now</span>
                </div>
            </div>
            <div class="card-details">
                <span class="tags-cinema block text-[9px] font-bold uppercase tracking-[0.2em] text-zinc-400 mb-2">Heavy Duty • Protection • Engineering</span>
                <h2 class="project-title-cinema text-2xl md:text-5xl font-light tracking-tight group-hover:opacity-60 transition-opacity">Industrial Pro</h2>
            </div>
        </a>

        <!-- Project 4: Automotive -->
        <a href="/automotive" class="project-card group no-underline text-inherit block">
            <div class="image-wrapper-cinema relative aspect-[16/10] overflow-hidden rounded-3xl bg-zinc-200 mb-6">
                <img src="/images/auto/category-auto.png" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" alt="Automotive Elite Aerosols" loading="lazy">
                <div class="absolute inset-0 flex items-center justify-center z-50">
                    <span class="category-pill bg-[#e11d48] text-white px-12 py-5 rounded-full text-lg font-black shadow-2xl hover:scale-110 transition-transform duration-300 uppercase tracking-wider">Shop Now</span>
                </div>
            </div>
            <div class="card-details">
                <span class="tags-cinema block text-[9px] font-bold uppercase tracking-[0.2em] text-zinc-400 mb-2">Car Care • Detail • Performance</span>
                <h2 class="project-title-cinema text-2xl md:text-5xl font-light tracking-tight group-hover:opacity-60 transition-opacity">Automotive Elite</h2>
            </div>
        </a>

        <!-- Project 5: Home & Living -->
        <a href="#" class="project-card group no-underline text-inherit block">
            <div class="image-wrapper-cinema relative aspect-[16/10] overflow-hidden rounded-3xl bg-zinc-200 mb-6">
                <img src="https://images.unsplash.com/photo-1583947215259-38e31be8751f?fm=webp&w=800&q=70&fit=crop" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" alt="Home Care" loading="lazy">
                <div class="absolute inset-0 flex items-center justify-center z-50">
                    <span class="category-pill bg-[#2b65ff] text-white px-12 py-5 rounded-full text-lg font-black shadow-2xl hover:scale-110 transition-transform duration-300 uppercase tracking-wider">Shop Now</span>
                </div>
            </div>
            <div class="card-details">
                <span class="tags-cinema block text-[9px] font-bold uppercase tracking-[0.2em] text-zinc-400 mb-2">Household • Care • Maintenance</span>
                <h2 class="project-title-cinema text-2xl md:text-5xl font-light tracking-tight group-hover:opacity-60 transition-opacity">Home & Living</h2>
            </div>
        </a>

        <!-- Project 6: Arts & Crafts -->
        <a href="/arts-and-crafts" class="project-card group no-underline text-inherit block">
            <div class="image-wrapper-cinema relative aspect-[16/10] overflow-hidden rounded-3xl bg-zinc-200 mb-6">
                <img src="/images/arts/category-arts.png" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" alt="Arts & Crafts Aerosols" loading="lazy">
                <div class="absolute inset-0 flex items-center justify-center z-50">
                    <span class="category-pill bg-[#f15a24] text-white px-12 py-5 rounded-full text-lg font-black shadow-2xl hover:scale-110 transition-transform duration-300 uppercase tracking-wider">Shop Now</span>
                </div>
            </div>
            <div class="card-details">
                <span class="tags-cinema block text-[9px] font-bold uppercase tracking-[0.2em] text-zinc-400 mb-2">Creative • Artistic • Craft</span>
                <h2 class="project-title-cinema text-2xl md:text-5xl font-light tracking-tight group-hover:opacity-60 transition-opacity">Arts & Crafts</h2>
            </div>
        </a>
    </div>
</section>

<style>
    .main-title {
        letter-spacing: -0.04em;
    }
    .category-pill {
        position: relative;
        z-index: 20;
    }
</style>

<script is:inline>
    window.addEventListener('load', () => {
        if (typeof gsap === 'undefined' || typeof SplitType === 'undefined') return;

        const titleContainer = document.querySelector('.title-container');
        const titleElement = document.getElementById('portfolio-title');
        const controls = document.querySelector('.header-controls');
        
        const splitTitle = new SplitType(titleElement, { types: 'chars' });
        
        gsap.set(titleContainer, { scale: 0.7, opacity: 0 });
        gsap.set(splitTitle.chars, { opacity: 0, filter: "blur(12px)", y: 20 });
        
        const headerTl = gsap.timeline({
            scrollTrigger: {
                trigger: '.portfolio-header',
                start: 'top 85%'
            }
        });

        headerTl.to(titleContainer, {
            scale: 1,
            opacity: 1,
            duration: 1.3,
            ease: "elastic.out(1, 0.75)",
            force3D: true
        })
        .to(splitTitle.chars, {
            opacity: 1,
            filter: "blur(0px)",
            y: 0,
            stagger: 0.025,
            duration: 1.1,
            ease: "power3.out"
        }, "-=0.8");

        gsap.to(controls, {
            scrollTrigger: {
                trigger: '.portfolio-header',
                start: 'top 85%'
            },
            y: 0,
            opacity: 1,
            duration: 0.8,
            ease: "power2.out",
            delay: 0.3
        });

        // Card Animations
        const cards = document.querySelectorAll('.project-card');
        cards.forEach(card => {
            const wrapper = card.querySelector('.image-wrapper-cinema');
            const img = card.querySelector('img');
            const tags = card.querySelector('.tags-cinema');
            const title = card.querySelector('.project-title-cinema');
            const splitCardTitle = new SplitType(title, { types: 'chars' });

            gsap.set(wrapper, { scale: 0.5, opacity: 0 });
            gsap.set(img, { scale: 1.4 });
            gsap.set(tags, { opacity: 0, filter: "blur(5px)" });
            gsap.set(splitCardTitle.chars, { opacity: 0, filter: "blur(12px)", y: 15 });

            const tl = gsap.timeline({
                scrollTrigger: {
                    trigger: card,
                    start: "top 95%",
                    toggleActions: "play none none reverse"
                }
            });

            tl.to(wrapper, { 
                scale: 1, 
                opacity: 1, 
                duration: 1.5, 
                ease: "elastic.out(1, 0.6)",
                force3D: true 
            })
            .to(img, { 
                scale: 1, 
                duration: 1.5, 
                ease: "power3.out",
                force3D: true 
            }, "<")
            .from(card.querySelector('.category-pill'), { 
                opacity: 0, 
                scale: 0.5, 
                y: 20, 
                duration: 0.8, 
                ease: "back.out(1.7)" 
            }, "-=1.0")
            .to(tags, { opacity: 1, filter: "blur(0px)", duration: 1 }, "-=1.1")
            .to(splitCardTitle.chars, { opacity: 1, filter: "blur(0px)", y: 0, stagger: 0.035, duration: 1.2 }, "-=0.9");
        });

        ScrollTrigger.refresh();
    });
</script>
