---
---
<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <div class="logo-big">SPRAY BAZAAR</div>
      <p>Premium aerosol solutions for the modern artist and professional.</p>
      <div class="social-links">
        <a href="#"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg></a>
        <a href="#"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg></a>
        <a href="#"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path></svg></a>
      </div>
    </div>
    
    <div class="footer-links">
      <div class="link-group">
        <h4>Shop</h4>
        <a href="#">Gloss Sprays</a>
        <a href="#">Matte Sprays</a>
        <a href="#">Specialty Coatings</a>
        <a href="#">Accessories</a>
      </div>
      <div class="link-group">
        <h4>Support</h4>
        <a href="#">FAQ</a>
        <a href="#">Shipping</a>
        <a href="#">Returns</a>
        <a href="#">Safety Data Sheets</a>
      </div>
      <div class="link-group">
        <h4>Company</h4>
        <a href="#">Our Story</a>
        <a href="#">Contact Us</a>
        <a href="#">Partners</a>
        <a href="#">Careers</a>
      </div>
    </div>
    
    <div class="footer-newsletter">
      <h4>Join the Bazaar</h4>
      <p>Subscribe for exclusive drops and tips.</p>
      <form class="newsletter-form">
        <input type="email" placeholder="Email address" required />
        <button type="submit">Subscribe</button>
      </form>
    </div>
  </div>
  
  <div class="container footer-bottom">
    <p>&copy; 2024 Spray Bazaar. All rights reserved.</p>
    <div class="legal-links">
      <a href="#">Privacy Policy</a>
      <a href="#">Terms of Service</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg-light);
    padding: 6rem 0 2rem;
    border-top: 1px solid var(--border-color);
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1.5fr 3fr 1.5fr;
    gap: 4rem;
    margin-bottom: 5rem;
  }
  .footer-brand .logo-big {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 1.5rem;
    letter-spacing: -0.05em;
  }
  .footer-brand p {
    font-size: 1rem;
    margin-bottom: 2rem;
    max-width: 300px;
  }
  .social-links {
    display: flex;
    gap: 1.5rem;
  }
  .social-links a {
    color: var(--text-dark);
    transition: var(--transition);
  }
  .social-links a:hover {
    color: var(--primary);
  }
  
  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .link-group h4 {
    margin-bottom: 1.5rem;
    font-size: 1.1rem;
  }
  .link-group a {
    display: block;
    margin-bottom: 0.75rem;
    font-size: 0.95rem;
    color: var(--text-muted);
  }
  .link-group a:hover {
    color: var(--text-dark);
  }
  
  .footer-newsletter h4 {
    margin-bottom: 1rem;
  }
  .footer-newsletter p {
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }
  .newsletter-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .newsletter-form input {
    padding: 0.75rem 1rem;
    border-radius: 8px;
    border: 1px solid var(--border-color);
    font-family: inherit;
  }
  .newsletter-form button {
    background: var(--text-dark);
    color: white;
    padding: 0.75rem;
    border-radius: 8px;
    font-weight: 700;
    transition: var(--transition);
  }
  .newsletter-form button:hover {
    background: var(--primary);
  }
  
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 2rem;
    border-top: 1px solid var(--border-color);
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  .legal-links {
    display: flex;
    gap: 2rem;
  }
  .legal-links a:hover {
    color: var(--text-dark);
  }
  
  @media (max-width: 1024px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
</style>
