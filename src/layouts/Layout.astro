---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Spray Bazaar - Premium Aerosol Spray Products" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
		<script is:inline src="https://cdn.tailwindcss.com"></script>
		<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
		<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
		<script is:inline src="https://unpkg.com/split-type"></script>
		<script is:inline src="https://unpkg.com/@studio-freight/lenis@1.0.33/dist/lenis.min.js"></script>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
	</head>
	<body>
		<slot />
		<script is:inline>
			// Global mobile check
			const isMobile = window.innerWidth < 768;
			if (isMobile) {
				document.documentElement.classList.add('is-mobile');
			}

			if (typeof Lenis !== 'undefined' && !isMobile) {
				const lenis = new Lenis({
					duration: 1.2,
					smooth: true,
					touchMultiplier: 2,
				});
				function raf(time) {
					lenis.raf(time);
					requestAnimationFrame(raf);
				}
				requestAnimationFrame(raf);
			}

			// Global kill GSAP ScrollTrigger on mobile
			window.addEventListener('load', () => {
				if (isMobile && typeof ScrollTrigger !== 'undefined') {
					ScrollTrigger.getAll().forEach(st => st.kill());
				}
			});
		</script>

	</body>
</html>
<style is:global>
	:root {
		--accent: 136, 58, 234;
		--accent-light: 224, 204, 250;
		--accent-dark: 49, 10, 101;
		--accent-gradient: linear-gradient(
			45deg,
			rgb(var(--accent)),
			rgb(var(--accent-light)) 30%,
			white 60%
		);
	}
</style>
