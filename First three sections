async function initHero() {
    const container=document.getElementById('hero-bg');
    const loader=document.getElementById('loader');
    let isResolved=false;

    const hideLoader=()=> {
        if (isResolved) return;
        isResolved=true;
        container.classList.remove('opacity-0');
        loader.style.opacity='0';

        setTimeout(()=> {
                if(loader.parentNode) loader.remove();
                initGSAP();
            }

            , 500);
    }

    ;

    const displayImage=(src)=> {
        const img=document.createElement('img');
        img.src=src;
        img.className="w-full h-full object-cover";

        img.onload=()=> {
            container.innerHTML='';
            container.appendChild(img);
            hideLoader();
        }

        ;

        img.onerror=()=> {
            const fallback="https://images.unsplash.com/photo-1496449903678-68ddcb189a24?auto=format&fit=crop&q=80&w=2000";
            if (src !==fallback) displayImage(fallback);
            else hideLoader();
        }

        ;
    }

    ;

    const prompt="Cinematic close-up POV shot looking down at a wet urban asphalt pavement with a small puddle reflecting the sky. A person's sleek footwear is partially visible stepping near the puddle. Moody atmospheric lighting, textures of wet ground, high contrast. 8k, photorealistic, luxury urban lifestyle aesthetic.";

    const timeoutId=setTimeout(()=> {
            if ( !isResolved) displayImage("https://images.unsplash.com/photo-1496449903678-68ddcb189a24?auto=format&fit=crop&q=80&w=2000");
        }

        , 6000);

    try {
        if( !apiKey) throw new Error("No API key"); // Trigger fallback faster if no key is provided here
        const response=await fetch(`https: //generativelanguage.googleapis.com/v1beta/models/imagen-4.0-generate-001:predict?key=${apiKey}`, {

            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            }

            ,
            body: JSON.stringify({
                instances: [ {
                    prompt: prompt
                }

                ], parameters: {
                    sampleCount: 1
                }
            })
    });
const result=await response.json();

if (result.predictions?.[0]) {
    clearTimeout(timeoutId);

    displayImage(`data:image/png; base64, $ {
            result.predictions[0].bytesBase64Encoded
        }

        `);
}

else throw new Error("No predictions");
}

catch (error) {
    displayImage("https://images.unsplash.com/photo-1496449903678-68ddcb189a24?auto=format&fit=crop&q=80&w=2000");
}
}

